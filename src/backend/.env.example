# ===== App =====
PORT=3000
NODE_ENV=development

# ===== Database =====
# Chuỗi kết nối MongoDB (Atlas hoặc local). KHÔNG commit giá trị thật.
MONGODB_URI=mongodb://localhost:27017/optic

# ===== Auth =====
# Chuỗi ngẫu nhiên đủ dài để ký JWT. Sinh bằng: openssl rand -hex 32
JWT_SECRET=change_me_use_a_long_random_hex_string
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# ===== Frontend =====
# Danh sách origin cho CORS, phân tách bằng dấu phẩy (KHÔNG khoảng trắng thừa).
# Origin ĐẦU TIÊN được dùng làm base cho các URL redirect (VNPay callback, verify email).
CLIENT_URL=http://localhost:5173

# ===== VNPay (sandbox) =====
# Đăng ký tài khoản sandbox tại https://sandbox.vnpayment.vn/devreg/
# rồi lấy Terminal ID (TmnCode) và Secret Key trong mục Thông tin tài khoản.
VNP_TMN_CODE=your_vnpay_terminal_id
VNP_HASH_SECRET=your_vnpay_hash_secret
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# ReturnURL: endpoint callback của backend. Local dev thường là:
#   http://localhost:3000/api/payment/vnpay-callback
VNP_RETURN_URL=http://localhost:3000/api/payment/vnpay-callback
